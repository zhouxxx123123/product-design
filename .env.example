# ==========================================
# 中科琉光调研工具 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
#
# 🔴 生产环境部署前必须替换以下变量（切勿使用默认值）：
#   DB_PASSWORD        — 数据库强密码
#   JWT_SECRET         — 至少 32 字符随机字符串
#   JWT_REFRESH_SECRET — 至少 32 字符随机字符串（与 JWT_SECRET 不同）
#   MINIO_ACCESS_KEY   — 替换 minioadmin
#   MINIO_SECRET_KEY   — 替换 minioadmin
#   MOONSHOT_API_KEY   — 从 platform.moonshot.cn 获取
#   TENCENT_SECRET_ID  — 从腾讯云控制台获取
#   TENCENT_SECRET_KEY — 从腾讯云控制台获取
#   FLOWER_AUTH        — 替换为 user:strong_password
#   CORS_ORIGIN        — 设置为生产域名
# ==========================================

# 环境设置
NODE_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=liuguang
DB_SSL=false

# ==========================================
# Redis配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# JWT配置
# ==========================================
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_characters_long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ==========================================
# MinIO对象存储配置
# ==========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=liuguang
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==========================================
# 腾讯ASR配置
# 获取地址: https://cloud.tencent.com/product/asr
# ==========================================
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_REGION=ap-beijing

# ==========================================
# Moonshot AI (Kimi) 配置
# 获取地址: https://platform.moonshot.cn/
# ==========================================
MOONSHOT_API_KEY=sk-your_moonshot_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# ==========================================
# ASR (语音识别) 配置
# ==========================================
ASR_PROVIDER=whisper
WHISPER_MODEL_SIZE=small
WHISPER_MODEL_DIR=/opt/models/whisper

# ==========================================
# 服务端口配置
# ==========================================
BACKEND_PORT=3000
FRONTEND_PORT=5173
AI_PORT=8000
FLOWER_PORT=5555

# ==========================================
# CORS配置
# ==========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ==========================================
# Flower监控认证
# ==========================================
FLOWER_AUTH=admin:your_flower_password
