#!/bin/bash

# Claude CLI + Chrome DevTools MCP 终端版前端联调工具
# 用法: ./claude-with-mcp [选项] [文件]

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 配置
CHROME_DEBUG_PORT=${CHROME_DEBUG_PORT:-9222}
CHROME_URL=${CHROME_URL:-http://127.0.0.1:$CHROME_DEBUG_PORT}
HEADLESS=${HEADLESS:-false}
VIEWPORT=${VIEWPORT:-1280x800}
SLIM_MODE=${SLIM_MODE:-false}
WITH_NETWORK=${WITH_NETWORK:-true}
WITH_PERFORMANCE=${WITH_PERFORMANCE:-true}

# 帮助文案
show_help() {
  cat << 'EOF'
🚀 Claude CLI + Chrome DevTools MCP 前端联调工具

用法:
  ./claude-with-mcp [选项] [文件...]

例子:
  # 交互模式（推荐）
  ./claude-with-mcp

  # 分析特定组件
  ./claude-with-mcp src/components/Button.tsx

  # 启用调试模式
  ./claude-with-mcp --debug

  # 简化模式（仅导航/脚本/截图）
  ./claude-with-mcp --slim

选项:
  -h, --help              显示帮助信息
  -d, --debug             启用 MCP 调试日志
  --slim                  启用简化模式（3个基础工具）
  --headless              无UI模式运行
  --no-network            禁用网络监控
  --no-performance        禁用性能分析
  --viewport SIZE         设置视口大小（默认 1280x800）
  --chrome-port PORT      Chrome 调试端口（默认 9222）
  --chrome-url URL        Chrome 调试 URL（默认 http://127.0.0.1:9222）
  --mode MODE             设置 Claude 对话模式
                          可选值: debug, design, performance, full (默认: full)

模式说明:
  debug       - 调试专家模式：关注 DOM/JS/错误
  design      - 设计审查模式：关注样式/布局/响应式
  performance - 性能优化模式：关注加载/渲染/网络
  full        - 完整模式：所有功能（默认）

环境变量:
  CHROME_DEBUG_PORT   Chrome 调试端口
  CHROME_URL          Chrome 调试 URL
  HEADLESS           是否无UI模式
  VIEWPORT           视口大小
  SLIM_MODE          是否简化模式

例子:
  HEADLESS=true ./claude-with-mcp --debug
  VIEWPORT=1920x1080 ./claude-with-mcp src/pages/
  ./claude-with-mcp --mode design --slim

EOF
}

# 检查 Chrome 调试端口
check_chrome_debug() {
  if ! nc -z 127.0.0.1 "$CHROME_DEBUG_PORT" 2>/dev/null; then
    echo "${YELLOW}⚠️  Chrome 调试端口 $CHROME_DEBUG_PORT 未响应${NC}"
    echo ""
    echo "请先启动 Chrome（带调试端口）:"
    echo ""
    echo "  ${BLUE}/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome \\${NC}"
    echo "  ${BLUE}  --remote-debugging-port=$CHROME_DEBUG_PORT \\${NC}"
    echo "  ${BLUE}  http://localhost:3000 &${NC}"
    echo ""
    read -p "已启动 Chrome? (y/n): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      exit 1
    fi
  else
    echo "${GREEN}✅ Chrome 调试端口 $CHROME_DEBUG_PORT 已就绪${NC}"
  fi
}

# 构建 MCP 配置
build_mcp_config() {
  local args='["--browserUrl", "'$CHROME_URL'"'
  
  [[ "$HEADLESS" == "true" ]] && args+=', "--headless"'
  [[ "$SLIM_MODE" == "true" ]] && args+=', "--slim"'
  [[ "$WITH_NETWORK" == "false" ]] && args+=', "--categoryNetwork", "false"'
  [[ "$WITH_PERFORMANCE" == "false" ]] && args+=', "--categoryPerformance", "false"'
  [[ -n "$VIEWPORT" ]] && args+=', "--viewport", "'$VIEWPORT'"'
  
  args+=']'
  
  echo '{
  "mcpServers": {
    "chrome-devtools": {
      "command": "chrome-devtools-mcp",
      "args": '$args'
    }
  }
}'
}

# 构建系统提示（基于模式）
build_system_prompt() {
  case "$USER_MODE" in
    debug)
      cat << 'PROMPT'
你是一个前端调试专家。我会请你帮我检查和调试网页问题。

你的超能力：
🔍 **DOM 检查** - 分析 HTML 结构和选择器
⚙️ **JavaScript 执行** - 运行代码获取数据和状态
🔴 **错误排查** - 识别浏览器错误和日志
📱 **兼容性测试** - 检查不同视口的表现

工作流：
1. 我描述问题 → 你截屏查看
2. 你用 JS 执行诊断 → 找出根因
3. 提出解决方案 → 验证修复

准备好了吗？告诉我你要调试什么！
PROMPT
      ;;
    design)
      cat << 'PROMPT'
你是一个前端设计审查专家。我会请你评审网页的设计和UI实现情况。

你的超能力：
🎨 **样式检查** - 分析 CSS 和设计一致性
📐 **布局验证** - 检查间距、对齐和响应式设计
✨ **视觉质量** - 评估动画、颜色、排版
📱 **跨设备测试** - 在不同视口验证表现

工作流：
1. 我展示设计稿或描述需求 → 你查看页面
2. 分析是否准确实现 → 列出差距
3. 提出改进建议 → 我修改代码

准备好做设计审查了吗？
PROMPT
      ;;
    performance)
      cat << 'PROMPT'
你是一个前端性能优化专家。我会请你分析和优化网页性能。

你的超能力：
⚡ **加载性能** - 分析首屏时间和资源加载
🎯 **渲染性能** - 查找 Reflow/Repaint 问题
🌐 **网络优化** - 分析 API 调用和数据传输
📊 **指标分析** - 使用 CrUX/Lighthouse 数据

工作流：
1. 我提供页面 URL → 你数据分析
2. 识别瓶颈 → 优先级排序
3. 给出优化方案 → 我逐一实施

让我们一起优化性能吧！
PROMPT
      ;;
    *)
      cat << 'PROMPT'
你是一个前端开发助手。我会请你帮我进行前端开发、测试和调试。

你有以下超能力：
📸 **页面截图** - 实时查看网页状态
🔍 **DOM 检查** - 分析页面结构
⚙️ **JS 执行** - 运行代码获取数据
🎨 **样式审查** - 检查 CSS 实现
📊 **性能分析** - 提供优化建议
🌐 **网络监控** - 查看 API 调用
🔴 **错误诊断** - 找出问题根因

常见用法：
- "截一下页面" → 我会拍照
- "页面有什么链接?" → 我会列出所有链接
- "执行 alert('hello')" → 我会在页面运行代码
- "分析加载性能" → 我会给出优化建议

让我们一起开发吧！🚀
PROMPT
      ;;
  esac
}

# 主函数
main() {
  local debug_mode=false
  local user_files=()
  USER_MODE="full"
  
  # 解析命令行参数
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help)
        show_help
        exit 0
        ;;
      -d|--debug)
        debug_mode=true
        shift
        ;;
      --slim)
        SLIM_MODE=true
        shift
        ;;
      --headless)
        HEADLESS=true
        shift
        ;;
      --no-network)
        WITH_NETWORK=false
        shift
        ;;
      --no-performance)
        WITH_PERFORMANCE=false
        shift
        ;;
      --viewport)
        VIEWPORT="$2"
        shift 2
        ;;
      --chrome-port)
        CHROME_DEBUG_PORT="$2"
        CHROME_URL="http://127.0.0.1:$2"
        shift 2
        ;;
      --chrome-url)
        CHROME_URL="$2"
        shift 2
        ;;
      --mode)
        USER_MODE="$2"
        shift 2
        ;;
      -*)
        echo "${RED}❌ 未知选项: $1${NC}"
        show_help
        exit 1
        ;;
      *)
        user_files+=("$1")
        shift
        ;;
    esac
  done
  
  # 检查 Chrome 调试端口
  check_chrome_debug
  
  echo ""
  echo "${BLUE}=== 配置信息 ===${NC}"
  echo "Chrome 调试 URL: $CHROME_URL"
  echo "视口大小: $VIEWPORT"
  echo "简化模式: $SLIM_MODE"
  echo "无UI模式: $HEADLESS"
  [[ "$USER_MODE" != "full" ]] && echo "对话模式: $USER_MODE"
  echo ""
  
  # 构建 MCP 配置
  MCP_CONFIG=$(build_mcp_config)
  
  # 构建 Claude 命令
  local claude_args=(--mcp-config "$MCP_CONFIG")
  
  [[ "$debug_mode" == "true" ]] && claude_args+=(--mcp-debug)
  
  # 添加系统提示
  local system_prompt
  system_prompt=$(build_system_prompt)
  claude_args+=(-p "$system_prompt")
  
  # 添加用户文件
  if [[ ${#user_files[@]} -gt 0 ]]; then
    claude_args+=("${user_files[@]}")
  fi
  
  # 启动 Claude
  echo "${GREEN}🚀 启动 Claude...${NC}"
  echo ""
  claude "${claude_args[@]}"
}

# 错误处理
trap 'echo "${RED}❌ 脚本中断${NC}"; exit 1' INT TERM

# 检查依赖
if ! command -v claude &> /dev/null; then
  echo "${RED}❌ Claude CLI 未安装${NC}"
  exit 1
fi

if ! command -v chrome-devtools-mcp &> /dev/null; then
  echo "${RED}❌ Chrome DevTools MCP 未安装${NC}"
  echo "请运行: npm install -g chrome-devtools-mcp"
  exit 1
fi

# 运行主函数
main "$@"
